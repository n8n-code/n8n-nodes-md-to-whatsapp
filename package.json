{
	"name": "@n8n-dev/n8n-nodes-md-to-whatsapp",
	"version": "1.0.4",
	"description": "n8n community node that converts Markdown text into WhatsApp-compatible formatting (*bold*, _italic_, ~strike~, ```monospace```)",
	"license": "MIT",
	"homepage": "https://github.com/n8n-code/n8n-nodes-md-to-whatsapp",
	"keywords": [
		"n8n",
		"n8n-community-node",
		"n8n-node",
		"n8n-community-node-package",
		"whatsapp",
		"markdown",
		"formatter",
		"transformation",
		"automation",
		"workflow"
	],
	"author": {
		"name": "n8n-code",
		"email": "kelvinandriancom@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/n8n-code/n8n-nodes-md-to-whatsapp.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"nodes": [
			"dist/nodes/MdToWhatsapp/MdToWhatsapp.node.js"
		]
	},
	"dependencies": {
		"n8n-workflow": "^2.28.1"
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "*",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "^5.9.3"
	}
}
